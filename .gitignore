# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.genkit/*
.env*

# firebase
firebase-debug.log
firestore-debug.log

# ─── Sensitive credentials & secrets ──────────────────────────────────────────
# Google Cloud / Firebase service account keys — NEVER commit these
online-catalog-*.json
*-service-account.json
*-serviceaccount.json
service-account*.json
serviceaccount*.json
# Generic GCP key files
*-firebase-adminsdk-*.json
# Any JSON file that looks like a GCP credential
*private_key*.json

# Android keystore reports & signing info — contain SHA fingerprints
signing_report.txt
keys_*.txt
*.keystore
*.jks

# Build & runtime logs — may contain env details, paths, or PII
*.log
build_*.log
build_*.txt
dev-server.*.log
run_android_log*.txt
android/build_*.txt
android/signing_report.txt

# Throwaway test/debug SQL scripts — may contain real phone numbers or user IDs
test_*.sql
debug_*.sql
# ───────────────────────────────────────────────────────────────────────────────

# OpenNext
.open-next

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
